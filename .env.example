# Copy this file to .env and fill in the values, then start the stack.
#   cp .env.example .env
#
# .env is gitignored (never commit real secrets — GitHub push protection will block them).

# MySQL root password (also used by backend MYSQL_PASSWORD and the mysql healthcheck).
MYSQL_ROOT_PASSWORD=root

# JWT signing key — must be >=256 bits for HS256.
JWT_SECRET=remitz-super-secret-key-that-is-at-least-256-bits-long-for-hs256

# Frontend public URL (used for email links); harmless default for local runs.
FRONTEND_URL=http://localhost:8098

# Brevo (Sendinblue) email API — REQUIRED for outbound email (demo-access, OTP, etc.).
# Get the key from the remitzglobal project's .env (BREVO_API_KEY) or your Brevo account.
BREVO_API_KEY=
BREVO_FROM_EMAIL=ramidiu@kreativwebsolutions.com
BREVO_FROM_NAME=Remitz
